# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=

# Supabase service role key (from Project Settings > API)
SUPABASE_SERVICE_KEY=

# Optional: Notion integration token (for Save to Notion feature)
# Get one at https://www.notion.so/my-integrations
NOTION_TOKEN=

# Optional: Notion page ID to save pastes to (the parent page)
NOTION_PAGE_ID=
