{
  "name": "mdshare-mcp",
  "version": "1.0.0",
  "description": "MCP server for mdshare — share markdown as beautifully rendered web pages",
  "type": "module",
  "bin": {
    "mdshare-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
